@model UpscaleWeb.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar Sesión - Upscale</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
</head>
<body class="bg-main-landscape bg-blur-layer">

    <!-- COMPONENTE: Header Rojo -->
    <partial name="_HeaderRed" />

    <div class="main-login-container">
        
        <div class="card-login-box">
            <h2 class="text-center mb-4 fw-bold" style="font-size: 1.5rem; color: #333;">Iniciar Sesión</h2>
            
            <!-- TABS SELECTOR (Estilo Imagen) -->
            <div class="login-tabs-container">
                <div class="login-tab active" id="tab-user" onclick="setLoginMethod('USUARIO')">USUARIO</div>
                <div class="login-tab" id="tab-doc" onclick="setLoginMethod('DOCUMENTO')">DOCUMENTO</div>
            </div>

            <form asp-action="Login" method="post">
                <div class="mb-4">
                    <label class="form-label-custom" id="label-user">ID Usuario</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-person fs-5"></i>
                        </span>
                        <input asp-for="Username" id="usernameInput" class="form-control border-start-0" placeholder="Ingresar usuario" oninput="validateForm()" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label-custom">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-lock fs-5"></i>
                        </span>
                        <input asp-for="Password" id="passwordInput" class="form-control border-start-0 border-end-0" type="password" placeholder="Ingresar contraseña" oninput="validateForm()" />
                        <span class="input-group-text bg-white border-start-0" style="cursor: pointer;" onclick="togglePassword()">
                            <i class="bi bi-eye fs-5" id="eyeIcon"></i>
                        </span>
                    </div>
                </div>

                <div class="mb-4">
                    <a href="/Account/ForgotPassword" class="forgot-password-link">¿Olvidó su contraseña?</a>
                </div>

                @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
                {
                    <div class="alert alert-danger py-2 small mb-3">@Model.ErrorMessage</div>
                }

                <button type="submit" id="btnLogin" class="btn btn-ingresar-custom" disabled>Ingresar</button>
            </form>
        </div>

        <div class="card-support-box">
            <i class="bi bi-headset fs-2 text-primary"></i>
            <p class="mb-0 fs-6 text-muted ms-3">
                ¿Necesita ayuda?, <a href="javascript:void(0)" class="text-decoration-none fw-bold" style="color: var(--active-blue);" onclick="showSupportToast()">contacte con el área de soporte.</a>
            </p>
        </div>

    </div>

    <!-- COMPONENTE: Toasts de Ayuda y Soporte -->
    <partial name="_SoporteToasts" />

    <!-- COMPONENTE: Logos Institucionales -->
    <partial name="_FooterLogos" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function setLoginMethod(method) {
            const tabUser = document.getElementById('tab-user');
            const tabDoc = document.getElementById('tab-doc');
            const labelUser = document.getElementById('label-user');
            const inputUser = document.getElementById('usernameInput');

            if (method === 'USUARIO') {
                tabUser.classList.add('active');
                tabDoc.classList.remove('active');
                labelUser.innerText = "Usuario";
                inputUser.placeholder = "Ingresar usuario";
            } else {
                tabDoc.classList.add('active');
                tabUser.classList.remove('active');
                labelUser.innerText = "Documento (DNI/CE)";
                inputUser.placeholder = "Ingresar documento";
            }
            validateForm();
        }

        function validateForm() {
            var user = document.getElementById("usernameInput").value;
            var pass = document.getElementById("passwordInput").value;
            var btn = document.getElementById("btnLogin");
            
            if (user.trim() !== "" && pass.length > 3) {
                btn.disabled = false;
            } else {
                btn.disabled = true;
            }
        }

        function togglePassword() {
            var input = document.getElementById("passwordInput");
            var icon = document.getElementById("eyeIcon");
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("bi-eye");
                icon.classList.add("bi-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("bi-eye-slash");
                icon.classList.add("bi-eye");
            }
        }
        document.addEventListener('DOMContentLoaded', function() {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('reason') === 'timeout') {
                showSystemNotification("Su sesión ha expirado debido a inactividad. Por favor, inicie sesión nuevamente.", "info");
            }
            
            @{
                var toastMessage = TempData["ToastMessage"] as string;
                var toastType = TempData["ToastType"] as string ?? "info";
                if (!string.IsNullOrEmpty(toastMessage))
                {
                    <text>showSystemNotification("@Html.Raw(toastMessage)", "@toastType");</text>
                }
            }
            validateForm();
        });
    </script>
</body>
</html>