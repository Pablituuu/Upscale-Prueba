@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Actualizar Contraseña - Upscale</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F8F9FA; }
        .card-auth { 
            max-width: 440px; 
            width: 100%; 
            border-radius: 24px; 
            padding: 40px; 
            background: white; 
            box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        }
        .icon-shield-box {
            width: 80px; height: 80px; 
            background-color: #EDF3FF; 
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 20px;
        }
        .icon-shield-box i { color: #2B6FFF; font-size: 2rem; }
        .form-label-custom { font-weight: 700; color: #1A1A1A; font-size: 0.9rem; margin-bottom: 8px; }
        .form-control-custom { 
            border-radius: 10px; 
            padding: 12px 15px; 
            border: 1.5px solid #E8E8E8; 
            color: #333; 
        }
        .form-control-custom::placeholder { color: #A0A0A0; }
        .btn-confirm-custom {
            background-color: #2B6FFF;
            border: none;
            border-radius: 50px;
            padding: 14px;
            font-weight: 700;
            color: white;
            transition: 0.3s;
            margin-top: 15px;
        }
        .btn-confirm-custom:hover { background-color: #1e5dd1; transform: translateY(-2px); box-shadow: 0 5px 15px rgba(43, 111, 255, 0.3); }
        .security-hint { font-size: 0.8rem; color: #666; line-height: 1.5; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center vh-100" style="background-image: url('/img/backgrounds/Illustration.png'); background-size: cover; background-position: center bottom; background-repeat: no-repeat;">

    <div class="card-auth text-center">
        <div class="icon-shield-box">
            <i class="bi bi-shield-lock-fill"></i>
        </div>

        <h2 class="fw-bold mb-2" style="color: #1A1A1A;">Actualizar Contraseña</h2>
        <p class="text-muted small mb-4">Por seguridad, debe establecer una nueva contraseña para continuar.</p>

        <div class="text-start mb-3">
            <label class="form-label-custom">Nueva Contraseña</label>
            <input type="password" id="newPass" class="form-control form-control-custom" placeholder="Mínimo 4 caracteres" oninput="liveValidate()" />
        </div>
        <div class="text-start mb-4">
            <label class="form-label-custom">Confirmar Contraseña</label>
            <input type="password" id="confirmPass" class="form-control form-control-custom" placeholder="Repita la clave" />
        </div>

        <div class="alert alert-light border shadow-sm p-3 mb-4 text-start rounded-4">
            <p class="mb-1 text-primary fw-bold" style="font-size: 0.75rem;"><i class="bi bi-shield-check me-1"></i>REQUISITOS DE SEGURIDAD:</p>
            <ul class="mb-0 security-hint ps-3">
                <li id="rule-nums">Al menos 3 números (0-9)</li>
                <li id="rule-lets">Al menos 3 letras</li>
                <li id="rule-caps">Al menos 1 letra mayúscula</li>
                <li id="rule-spec">Al menos 1 carácter especial (*$#...)</li>
            </ul>
        </div>

        <button class="btn btn-confirm-custom w-100" id="btnGuardar" onclick="savePassword()">
            Guardar y Entrar
        </button>
    </div>

    <!-- COMPONENTE: Toasts -->
    <partial name="_SoporteToasts" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function liveValidate() {
            const pass = document.getElementById('newPass').value;
            
            const nums = (pass.match(/[0-9]/g) || []).length;
            const lets = (pass.match(/[a-zA-Z]/g) || []).length;
            const hasCaps = /[A-Z]/.test(pass);
            const hasSpec = /[^a-zA-Z0-9]/.test(pass);

            document.getElementById('rule-nums').style.color = nums >= 3 ? '#198754' : '#dc3545';
            document.getElementById('rule-lets').style.color = lets >= 3 ? '#198754' : '#dc3545';
            document.getElementById('rule-caps').style.color = hasCaps ? '#198754' : '#dc3545';
            document.getElementById('rule-spec').style.color = hasSpec ? '#198754' : '#dc3545';
            
            const isValid = (nums >= 3 && lets >= 3 && hasCaps && hasSpec);
            document.getElementById('btnGuardar').style.opacity = isValid ? '1' : '0.6';
        }

        async function savePassword() {
            const pass = document.getElementById('newPass').value;
            const confirm = document.getElementById('confirmPass').value;

            if (pass !== confirm) {
                showSystemNotification("Las contraseñas no coinciden.", "error"); return;
            }

            const fd = new URLSearchParams();
            fd.append('newPass', pass);

            const response = await fetch('/Account/ChangePassword', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: fd
            });

            const result = await response.json();
            if (result.success) {
                showSystemNotification("Contraseña actualizada. Ingresando...", "success");
                setTimeout(() => window.location.href = '/Account/Profile', 1500);
            } else {
                showSystemNotification(result.message, "error");
            }
        }
        liveValidate();
    </script>
</body>
</html>
