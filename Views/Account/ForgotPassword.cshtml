@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar Acceso - Upscale</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #F8F9FA; }
        .card-auth { 
            max-width: 480px; 
            width: 100%; 
            border-radius: 28px; 
            padding: 40px; 
            background: white; 
            box-shadow: 0 12px 50px rgba(0,0,0,0.06);
        }
        .icon-shield-box {
            width: 80px; height: 80px; 
            background-color: #FFF3E0; 
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 25px;
        }
        .icon-shield-box i { color: #F57C00; font-size: 2.2rem; }
        .form-label-custom { font-weight: 700; color: #1A1A1A; font-size: 0.85rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; }
        .form-control-custom { 
            border-radius: 12px; 
            padding: 14px 18px; 
            border: 1.5px solid #E8E8E8; 
            color: #333; 
            font-size: 0.95rem;
            background-color: #FAFAFA;
        }
        .form-control-custom:focus { 
            background-color: white; 
            border-color: #2B6FFF; 
            box-shadow: 0 0 0 4px rgba(44, 111, 255, 0.1); 
        }
        .btn-confirm-custom {
            background-color: #2B6FFF;
            border: none;
            border-radius: 50px;
            padding: 16px;
            font-weight: 700;
            color: white;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(43, 111, 255, 0.2);
        }
        .btn-confirm-custom:hover { background-color: #1e5dd1; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(43, 111, 255, 0.4); }
        .btn-support-custom {
            background-color: transparent;
            border: 2px solid #E8E8E8;
            border-radius: 50px;
            padding: 12px;
            font-weight: 600;
            color: #666;
            transition: 0.3s;
            font-size: 0.85rem;
        }
        .btn-support-custom:hover { background-color: #f8f9fa; border-color: #ccc; color: #333; }
        .divider { height: 1.5px; background: #EEE; margin: 30px 0; position: relative; }
        .divider::after { content: 'O SI NO RECORDAR'; position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: white; padding: 0 15px; font-size: 0.65rem; color: #AAA; font-weight: 700; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center vh-100 p-3" style="background-image: url('/img/backgrounds/Illustration.png'); background-size: cover; background-position: center bottom; background-repeat: no-repeat;">

    <div class="card-auth text-center">
        <div class="icon-shield-box">
            <i class="bi bi-shield-lock"></i>
        </div>

        <h2 class="fw-bold mb-2" style="color: #1A1A1A; font-size: 1.6rem;">¿Olvidó su contraseña?</h2>
        <p class="text-muted small mb-4 px-3" style="line-height: 1.6;">Ingrese sus coordenadas de identidad para restablecer su acceso al sistema de seguridad.</p>

        <form id="forgotForm" class="text-start">
            <div class="mb-3">
                <label class="form-label-custom">Nombre Completo</label>
                <input type="text" id="nombreCompleto" class="form-control form-control-custom" placeholder="Ej. Pablito Jean Pool Silva Inca" required />
            </div>
            
            <div class="mb-3">
                <label class="form-label-custom">Documento (DNI/CE)</label>
                <input type="text" id="dni" class="form-control form-control-custom" placeholder="Ingresar número de identificación" required />
            </div>

            <div class="mb-4">
                <label class="form-label-custom">Nombre de Usuario (ID)</label>
                <input type="text" id="username" class="form-control form-control-custom" placeholder="pablito.silvai" required />
            </div>

            <button type="button" class="btn btn-confirm-custom w-100" onclick="handleReset()">
                Restablecer Credenciales
            </button>
        </form>

        <div class="divider"></div>

        <p class="small text-muted mb-3">Si no recuerda alguno de estos datos de identidad corporativa:</p>
        <button class="btn btn-support-custom w-100 d-flex align-items-center justify-content-center gap-2" onclick="showSupportToast()">
            <i class="bi bi-headset"></i> Contactar con Soporte Técnico
        </button>

        <a href="/Account/Login" class="text-decoration-none small d-block mt-4 fw-bold" style="color: #2B6FFF;">
             Volver al Inicio de Sesión
        </a>
    </div>

    <partial name="_SoporteToasts" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        async function handleReset() {
            const username = document.getElementById('username').value.trim();
            const dni = document.getElementById('dni').value.trim();
            const nombre = document.getElementById('nombreCompleto').value.trim();

            if (!username || !dni || !nombre) {
                showSystemNotification("Por favor, complete todas las coordenadas de identidad.", "error");
                return;
            }

            const btn = document.querySelector('.btn-confirm-custom');
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Validando...';
            btn.disabled = true;

            const fd = new URLSearchParams();
            fd.append('username', username);
            fd.append('dni', dni);
            fd.append('nombreCompleto', nombre);

            try {
                const response = await fetch('/Account/ForgotPassword', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: fd
                });

                const result = await response.json();
                if (result.success) {
                    showSystemNotification(result.message, "success");
                    setTimeout(() => window.location.href = '/Account/Login', 4000);
                } else {
                    showSystemNotification(result.message, "error");
                }
            } catch (e) { 
                showSystemNotification("Error de conexión.", "error"); 
            } finally {
                btn.innerHTML = 'Restablecer Credenciales';
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
