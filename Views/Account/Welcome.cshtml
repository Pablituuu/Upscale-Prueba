@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>¡Bienvenid@@! - Activación de Cuenta</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <!-- Reutilizamos el CSS del Login para el fondo -->
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Public+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Public Sans', sans-serif; overflow: hidden; }
        
        /* Ajustes específicos para Welcome */
        .welcome-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            padding: 50px 40px;
            max-width: 450px;
            text-align: center;
        }

        .rocket-circle {
            width: 80px;
            height: 80px;
            background-color: #F8F4F4; /* Fondo rojizo suave */
            color: #C1272D; /* Color del rocket */
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            font-size: 2.5rem;
        }

        .btn-ingresar {
            background-color: #385794;
            border: none;
            padding: 12px 0;
            font-weight: 500;
            border-radius: 6px;
        }
        
        .header-bar {
            background-color: #7D2828; /* Marrón/Rojo oscuro según imagen */
            color: white;
            padding: 12px 25px;
            display: flex;
            justify-content: flex-end;
            position: absolute;
            top: 0; left: 0; right: 0;
            z-index: 10;
        }


        /* Animación suave */
        .welcome-card-box {
            animation: slideUp 0.6s ease-out;
        }
        @@keyframes slideUp { 
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body class="bg-main-landscape bg-blur-layer">

    <!-- Header con pregunta -->
    <div class="header-bar">
        <i class="bi bi-question-lg fs-5"></i>
    </div>

    <!-- Contenido central -->
    <div class="flex-grow-1 d-flex align-items-center justify-content-center" style="position: relative; z-index: 5;">
        <div class="welcome-card welcome-card-box">
            <div class="rocket-circle">
                <i class="bi bi-rocket-takeoff"></i>
            </div>
            
            <h1 class="fw-bold mb-3" style="color: #2D2E32;">¡Bienvenid@@!</h1>
            
            <p class="text-muted mb-5 px-3" style="font-size: 1.05rem; line-height: 1.6;">
                Su cuenta en el aplicativo X está activada.<br>
                Ya puede iniciar sesión.
            </p>

            <a asp-action="Login" class="btn btn-primary btn-ingresar w-100">
                Iniciar sesión
            </a>
        </div>
    </div>

    <!-- Pie de página Institucional (Llama al partial que ya tiene la clase .footer-logos-box) -->
    @await Html.PartialAsync("_FooterLogos")

</body>
</html>
