<!-- Modal de Aviso de Sesión -->
<div class="modal fade" id="sessionExpiracyModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <div class="bg-warning bg-opacity-10 d-inline-flex p-3 rounded-circle shadow-sm">
                        <i class="bi bi-exclamation-triangle-fill text-warning fs-1"></i>
                    </div>
                </div>
                <h4 class="fw-bold mb-3" style="color: #333;">Su sesión está a punto de expirar</h4>
                <p class="text-muted mb-4 border-top pt-3">
                    Por seguridad, su sesión expirará en <span id="sessionCountdown" class="fw-bold text-dark fs-5">60</span> segundos. 
                    <br>Para continuar, seleccione <strong>"Extender sesión"</strong>.
                </p>
                <div class="d-grid">
                    <button type="button" class="btn btn-warning text-dark fw-bold rounded-pill p-3" id="btnExtendSession" onclick="resetActivity()">
                        Extender sesión
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let inactivityTime = 0;
    let countdownTime = 60;
    let inactivityInterval = null;
    let countdownInterval = null;
    let sessionModal = null;

    // 1. Iniciar temporizador de inactividad
    function initInactivityTimer() {
        inactivityInterval = setInterval(() => {
            inactivityTime++;
            if (inactivityTime >= 1200) { // 20 minutos de inactividad
                showSessionWarning();
            }
        }, 1000);
    }

    // 2. Mostrar Advertencia
    function showSessionWarning() {
        clearInterval(inactivityInterval); // Parar contador de inactividad
        
        if (!sessionModal) {
            sessionModal = new bootstrap.Modal(document.getElementById('sessionExpiracyModal'));
        }
        sessionModal.show();
        
        // Iniciar cuenta regresiva
        countdownTime = 60;
        document.getElementById('sessionCountdown').innerText = countdownTime;
        
        countdownInterval = setInterval(() => {
            countdownTime--;
            document.getElementById('sessionCountdown').innerText = countdownTime;
            
            if (countdownTime <= 0) {
                forceLogout();
            }
        }, 1000);
    }

    // 3. Extender Sesión (Reset)
    function resetActivity() {
        inactivityTime = 0;
        clearInterval(countdownInterval);
        
        if (sessionModal) {
            sessionModal.hide();
        }
        
        // Reset manual
        initInactivityTimer();
        
        // Opcional: Llamada al server para refrescar cookie si fuera necesario
        fetch('/Account/Profile'); 
    }

    // 4. Salto de Sesión
    function forceLogout() {
        window.location.href = '/Account/Logout?reason=timeout';
    }

    // 5. Resetear inactividad al mover el mouse o teclado (mientras no esté el modal)
    document.addEventListener('mousemove', () => { if (inactivityInterval) inactivityTime = 0; });
    document.addEventListener('keypress', () => { if (inactivityInterval) inactivityTime = 0; });
    document.addEventListener('click', () => { if (inactivityInterval) inactivityTime = 0; });

    // Arrancar al cargar la página
    document.addEventListener('DOMContentLoaded', initInactivityTimer);
</script>

<style>
    #sessionExpiracyModal .modal-content {
        border-radius: 20px;
    }
    #btnExtendSession {
        transition: transform 0.2s;
        background-color: #b8860b !important; /* Dorado oscuro segun foto */
        border-color: #b8860b !important;
        color: white !important;
    }
    #btnExtendSession:hover {
        transform: scale(1.02);
        opacity: 0.9;
    }
</style>
